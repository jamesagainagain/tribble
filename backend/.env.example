# Tribble backend env. Copy to .env and set values. Never commit .env.
#
# Required for core app (map, clusters, reports, relief, routes):
#   TRIBBLE_SUPABASE_URL, TRIBBLE_SUPABASE_SERVICE_KEY, TRIBBLE_SUPABASE_ANON_KEY
#
# Optional – features degrade gracefully if unset:
#   TRIBBLE_ANTHROPIC_API_KEY  → LLM narrative (HELIOS, dashboard, routes, satellite AI). Was TRIBBLE_GEMINI_API_KEY; use Anthropic key now.
#   TRIBBLE_ACLED_API_KEY     → ACLED event ingest
#   TRIBBLE_OPENWEATHERMAP_API_KEY → Weather at point / validity
#   TRIBBLE_FLOCK_API_KEY     → FLock LLM (when TRIBBLE_ENABLE_FLOCK=true)
#   TRIBBLE_ZAI_API_KEY       → Z.ai provider
#   TRIBBLE_SATELLITE_ML_*    → Satellite ML when TRIBBLE_ENABLE_SATELLITE_ML=true
#
# Supabase: Project URL from Dashboard → Project Settings. Service key = "Secret" (sb_secret_...) or legacy "service_role" JWT.
TRIBBLE_SUPABASE_URL=https://your-project-ref.supabase.co
TRIBBLE_SUPABASE_SERVICE_KEY=your-secret-or-service-role-key
TRIBBLE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
TRIBBLE_ACLED_API_KEY=
TRIBBLE_ACLED_EMAIL=
TRIBBLE_OPENWEATHERMAP_API_KEY=
TRIBBLE_ZAI_API_KEY=
TRIBBLE_ENABLE_OPENCLAW=false
TRIBBLE_ENABLE_FLOCK=false
TRIBBLE_ENABLE_SATELLITE_ML=false
TRIBBLE_FLOCK_API_BASE_URL=https://api.flock.io/v1
TRIBBLE_FLOCK_API_KEY=
TRIBBLE_FLOCK_MODEL=meta-llama/Llama-3.3-70B-Instruct
TRIBBLE_SENTINEL_STAC_URL=https://planetarycomputer.microsoft.com/api/stac/v1
TRIBBLE_SATELLITE_CLOUD_COVER_THRESHOLD=40.0
TRIBBLE_SATELLITE_MIN_SCL_CLEAR_PCT=60.0
TRIBBLE_SATELLITE_CHANGE_WINDOW_DAYS=14
TRIBBLE_SATELLITE_ML_PROVIDER_URL=
TRIBBLE_SATELLITE_ML_API_KEY=
# Anthropic Claude (satellite AI, HELIOS, analysis, routes). Use claude-3-5-haiku (4.5 Haiku).
TRIBBLE_ANTHROPIC_API_KEY=
TRIBBLE_LLM_MODEL=claude-3-5-haiku-20241022
